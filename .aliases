alias dss_env='source ~/venvs/dss/bin/activate'
alias adw_env='source ~/venvs/adw/bin/activate'
alias sc_env='source ~/venvs/servicecreator/bin/activate'
alias castor_env='source ~/venvs/castor/bin/activate'
alias dafenv='source ~/venvs/daf/bin/activate'

# local server aliases
alias nas="ssh -p 45000 'parikshit_admin@192.168.1.2'"

# tmux sessions
t() {
  # Create session in background if it doesn't exist
  tmux new-session -d -s "$1" 2>/dev/null
  
  if [ -n "$TMUX" ]; then
    # If inside tmux: switch to it
    tmux switch-client -t "$1"
  else
    # If outside tmux: attach to it
    tmux attach-session -t "$1"
  fi
}

# DSS AWS Environment
alias dfdev="aws sso login --profile dev-df-admin && export AWS_PROFILE=dev-df-admin && export AWS_REGION=eu-west-1"
alias dfuat="aws sso login --profile uat-df-admin && export AWS_PROFILE=uat-df-admin && export AWS_REGION=eu-west-1"
alias dfprod="aws sso login --profile prod-df-admin && export AWS_PROFILE=prod-df-admin && export AWS_REGION=eu-west-1"
alias dfcicd="aws sso login --profile cicd && export AWS_PROFILE=cicd && export AWS_REGION=eu-west-1"
alias lsrepo="aws codecommit list-repositories --region eu-west-1 --profile cicd | jq -r '.repositories[] | .repositoryName'"

alias eksdev="aws eks --region eu-west-1 update-kubeconfig --name dev-datafactory"
alias eksuat="aws eks --region eu-west-1 update-kubeconfig --name uat-datafactory"
alias eksprod="aws eks --region eu-west-1 update-kubeconfig --name prod-datafactory"
