# =============================================================================
# TMUX
# =============================================================================

# Create or attach/switch to a named session
t() {
  tmux new-session -d -s "$1" 2>/dev/null
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$1"
  else
    tmux attach-session -t "$1"
  fi
}

# Tab-complete session names for t()
if [ -n "$BASH_VERSION" ]; then
    _t_complete() { tmux list-sessions -F '#S' 2>/dev/null; }
    complete -F _t_complete t
fi
# Note: zsh completion for t() can be added manually if needed via compdef


# =============================================================================
# DSS AWS — SSO + PROFILE SWITCHING
# =============================================================================

# AWS region
export DF_AWS_REGION="eu-west-1"

# Helper function to get bastion instance ID from profile
_df_bastion_instance() {
    case "$AWS_PROFILE" in
        dev-df-admin)  echo "i-065b5c527a1890cbe" ;;
        uat-df-admin)  echo "i-042d4e5d9c129220d" ;;
        prod-df-admin) echo "i-007c3baf00fcdc433" ;;
    esac
}

# Helper function to get RDS endpoint from profile
_df_rds_endpoint() {
    case "$AWS_PROFILE" in
        dev-df-admin)  echo "rds-dev-datafactory-instance-1.ciyx0wg9ft4f.eu-west-1.rds.amazonaws.com" ;;
        uat-df-admin)  echo "rds-uat-datafactory-instance-1.ciyx0wg9ft4f.eu-west-1.rds.amazonaws.com" ;;
        prod-df-admin) echo "rds-prod-datafactory-instance-1.ciyx0wg9ft4f.eu-west-1.rds.amazonaws.com" ;;
    esac
}

# Helper function to get Redshift endpoint from profile
_df_redshift_endpoint() {
    case "$AWS_PROFILE" in
        dev-df-admin)  echo "rs-dev-datafactory-001.cymikxohtjhl.eu-west-1.redshift.amazonaws.com" ;;
        uat-df-admin)  echo "rs-uat-datafactory-001.cymikxohtjhl.eu-west-1.redshift.amazonaws.com" ;;
        prod-df-admin) echo "rs-prod-datafactory-001.cn7jv4zmgtoa.eu-west-1.redshift.amazonaws.com" ;;
    esac
}

# AWS Profile Switching
# Auto-validates SSO session and logs in if expired
dfenv() {
    local env="$1"
    local profile

    case "$env" in
        dev)  profile="dev-df-admin"  ;;
        uat)  profile="uat-df-admin"  ;;
        prod) profile="prod-df-admin" ;;
        cicd) profile="cicd"          ;;
        *)
            echo "Usage: dfenv <dev|uat|prod|cicd>"
            return 1
            ;;
    esac

    # Check if SSO session is valid
    if ! aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
        echo "⚠ SSO session expired or invalid. Running dflogin..."
        aws sso login --sso-session df-shared || aws sso login --profile "$profile"

        # Verify login was successful
        if ! aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
            echo "✗ Login failed. Please check your SSO configuration."
            return 1
        fi
    fi

    export AWS_PROFILE="$profile"
    export AWS_REGION="$DF_AWS_REGION"
    echo "✓ AWS_PROFILE=$AWS_PROFILE  AWS_REGION=$AWS_REGION"
}

# Profile switching aliases
alias dflogin='aws sso login --sso-session df-shared || aws sso login --profile dev-df-admin'
alias dfdev='dfenv dev'
alias dfuat='dfenv uat'
alias dfprod='dfenv prod'
alias dfcicd='dfenv cicd'

# Show current AWS profile
alias awsprofile='echo ${AWS_PROFILE:-not set}'

# List CodeCommit repos (uses current profile/region)
alias lsrepo="aws codecommit list-repositories --region $DF_AWS_REGION | jq -r '.repositories[] | .repositoryName'"


# =============================================================================
# DSS EKS — KUBECONFIG SWITCHING
# =============================================================================

# Derives the cluster name from AWS_PROFILE set by dfenv, then updates
# kubeconfig. No argument needed — just run dfenv first, then eks.
#
# Profile → cluster mapping:
#   dev-df-admin  → dev-datafactory
#   uat-df-admin  → uat-datafactory
#   prod-df-admin → prod-datafactory
#
# Usage:
#   dfdev && eks        # switch AWS profile, then sync kubeconfig
#   dfprod && eks       # same for prod
eks() {
    if [[ -z "$AWS_PROFILE" ]]; then
        echo "⚠ AWS_PROFILE is not set. Run 'dfdev/dfuat/dfprod' first."
        return 1
    fi

    local cluster

    case "$AWS_PROFILE" in
        dev-df-admin)  cluster="dev-datafactory"  ;;
        uat-df-admin)  cluster="uat-datafactory"  ;;
        prod-df-admin) cluster="prod-datafactory" ;;
        *)
            echo "⚠ No EKS cluster mapped for AWS_PROFILE='$AWS_PROFILE'."
            echo "  Known profiles: dev-df-admin | uat-df-admin | prod-df-admin"
            return 1
            ;;
    esac

    echo "→ Updating kubeconfig for '$cluster' (profile: $AWS_PROFILE)..."
    aws eks --region "$DF_AWS_REGION" update-kubeconfig --name "$cluster"
    echo "✓ kubectl context → $cluster"
}



# =============================================================================
# DSS PORT FORWARDS — AIRFLOW / REDASH / RDS / REDSHIFT
# =============================================================================

# Unalias old port-forward aliases (from previous version)
unalias pfairflow pfredash 2>/dev/null

# Airflow — environment-specific ports (dev:5000, uat:5001, prod:5002)
# Auto-updates EKS context based on active AWS_PROFILE. Just run dfdev/dfuat/dfprod first.
pfairflow() {
    # Auto-update EKS context (includes AWS_PROFILE check)
    eks || return 1

    local svc
    local port

    case "$AWS_PROFILE" in
        dev-df-admin)  svc="dev-api-server";  port="5000" ;;
        uat-df-admin)  svc="uat-api-server";  port="5001" ;;
        prod-df-admin) svc="prod-api-server"; port="5002" ;;
    esac

    echo "→ Port-forwarding $svc to localhost:$port..."
    kubens airflow && kubectl port-forward "services/$svc" "$port:8080"
}

# Redash — environment-specific ports (dev:5100, uat:5101, prod:5102)
pfredash() {
    # Auto-update EKS context (includes AWS_PROFILE check)
    eks || return 1

    local port

    case "$AWS_PROFILE" in
        dev-df-admin)  port="5100" ;;
        uat-df-admin)  port="5101" ;;
        prod-df-admin) port="5102" ;;
    esac

    echo "→ Port-forwarding Redash to localhost:$port..."
    kubens redash && kubectl port-forward services/redash "$port:80"
}

# Port-forward checks
alias pgcheck='lsof -i :5432 -i :5433 -i :5434'
alias rscheck='lsof -i :5439 -i :5440 -i :5441'
alias afcheck='lsof -i :5000 -i :5001 -i :5002'
alias redashcheck='lsof -i :5100 -i :5101 -i :5102'

# =============================================================================
# DSS SSM TUNNELS — BASTION / RDS / REDSHIFT
# =============================================================================

# Bastion shell session - derives instance from active AWS_PROFILE
bs() {
    if [[ -z "$AWS_PROFILE" ]]; then
        echo "⚠ AWS_PROFILE is not set. Run 'dfdev/dfuat/dfprod' first."
        return 1
    fi

    local instance=$(_df_bastion_instance)
    if [[ -z "$instance" ]]; then
        echo "⚠ No bastion instance mapped for AWS_PROFILE='$AWS_PROFILE'."
        return 1
    fi

    echo "→ Connecting to bastion ($instance)..."
    aws ssm start-session --target="$instance" --document-name AWS-StartInteractiveCommand --parameters command='bash -l'
}

# RDS (Postgres) tunnel via bastion — environment-specific ports (dev:5432, uat:5433, prod:5434)
pgfwd() {
    if [[ -z "$AWS_PROFILE" ]]; then
        echo "⚠ AWS_PROFILE is not set. Run 'dfdev/dfuat/dfprod' first."
        return 1
    fi

    local instance=$(_df_bastion_instance)
    local endpoint=$(_df_rds_endpoint)
    local port

    case "$AWS_PROFILE" in
        dev-df-admin)  port="5432" ;;
        uat-df-admin)  port="5433" ;;
        prod-df-admin) port="5434" ;;
    esac

    if [[ -z "$instance" || -z "$endpoint" ]]; then
        echo "⚠ No RDS configuration for AWS_PROFILE='$AWS_PROFILE'."
        return 1
    fi

    echo "→ Port-forwarding RDS to localhost:$port..."
    aws ssm start-session \
        --target "$instance" \
        --document-name AWS-StartPortForwardingSessionToRemoteHost \
        --parameters host="$endpoint",portNumber='5432',localPortNumber="$port"
}

# Redshift tunnel via bastion — environment-specific ports (dev:5439, uat:5440, prod:5441)
rsfwd() {
    if [[ -z "$AWS_PROFILE" ]]; then
        echo "⚠ AWS_PROFILE is not set. Run 'dfdev/dfuat/dfprod' first."
        return 1
    fi

    local instance=$(_df_bastion_instance)
    local endpoint=$(_df_redshift_endpoint)
    local port

    case "$AWS_PROFILE" in
        dev-df-admin)  port="5439" ;;
        uat-df-admin)  port="5440" ;;
        prod-df-admin) port="5441" ;;
    esac

    if [[ -z "$instance" || -z "$endpoint" ]]; then
        echo "⚠ No Redshift configuration for AWS_PROFILE='$AWS_PROFILE'."
        return 1
    fi

    echo "→ Port-forwarding Redshift to localhost:$port..."
    aws ssm start-session \
        --target "$instance" \
        --document-name AWS-StartPortForwardingSessionToRemoteHost \
        --parameters host="$endpoint",portNumber='5439',localPortNumber="$port"
}

